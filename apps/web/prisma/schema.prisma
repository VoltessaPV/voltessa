generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  OWNER
  OPERATOR
  VIEWER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  role UserRole @default(VIEWER)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  accounts Account[]
  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String

  refresh_token String? @db.Text
  access_token  String? @db.Text
  expires_at    Int?
  token_type    String?
  scope         String?
  id_token      String? @db.Text
  session_state String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Organization {
  id String @id @default(cuid())

  name String

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  onboardingCompletedAt DateTime?

  users                  User[]
  plants                 Plant[]
  fusionSolarConnections FusionSolarConnection[]

  automationSettings AutomationSettings?
  deviceTelemetry    DeviceTelemetry[]
}

model Plant {
  id String @id @default(cuid())

  name String

  vendor String @default("Huawei")

  timezone String @default("Europe/Sofia")

  stationCode String?
  plantCode   String?

  capacityKw Decimal? @db.Decimal(10, 2)

  latitude  Decimal? @db.Decimal(9, 6)
  longitude Decimal? @db.Decimal(9, 6)

  country String?
  city    String?
  address String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String

  organization Organization @relation(fields: [organizationId], references: [id])

  devices Device[]

  telemetrySnapshots PlantTelemetrySnapshot[]
  deviceTelemetry    DeviceTelemetry[]

  @@unique([organizationId, stationCode])
}

model FusionSolarConnection {
  id String @id @default(cuid())

  organizationId String

  provider String @default("HuaweiFusionSolar")

  accessToken  String  @db.Text
  refreshToken String? @db.Text

  tokenType String?
  scope     String?

  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider])
}

model Device {
  id String @id @default(cuid())

  plantId String

  vendor String @default("Huawei")

  devDn     String
  devName   String
  devTypeId Int

  /// Huawei numeric device identifier.
  /// Used only for Huawei API calls (for example getDevRealKpi).
  /// Refreshed on every device synchronization.
  /// Not a Voltessa business identifier.
  huaweiDeviceId BigInt?

  esnCode String?
  invType String?
  model   String?

  optimizerNumber Int?
  softwareVersion String?

  latitude  Decimal? @db.Decimal(9, 6)
  longitude Decimal? @db.Decimal(9, 6)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plant Plant @relation(fields: [plantId], references: [id], onDelete: Cascade)

  deviceTelemetry DeviceTelemetry[]

  @@unique([plantId, devDn])
  @@index([plantId])
  @@index([esnCode])
}

/// Per-organization automation configuration. Foundation for the Voltessa
/// Automation MVP - the Decision Engine (lib/automation/export-decision.ts)
/// reads these values as plain business inputs; it never queries this model
/// itself. `energyTrader` is a free-text placeholder today so it can later
/// evolve into a real trader integration (e.g. becoming a foreign key into
/// a future TraderIntegration table) without renaming this field. Transfer
/// costs, imbalance costs, and margins are deliberately not modeled here -
/// later milestone.
model AutomationSettings {
  id String @id @default(cuid())

  organizationId String @unique

  automationEnabled Boolean @default(false)

  minimumExportPrice Decimal @default(15.00) @db.Decimal(10, 2)

  /// Currency the organization expects minimumExportPrice to be denominated
  /// in. Does not trigger any currency conversion today - MarketPrice rows
  /// read through the Market Price Provider are compared to
  /// minimumExportPrice assuming they already match (true for the current
  /// single-market/EUR MVP scope). Converting across currencies is explicit
  /// future work, not done here.
  currency String @default("EUR")

  energyTrader String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

/// Persisted, normalized market prices (currently: ENTSO-E day-ahead
/// electricity prices). Populated only by
/// lib/market-price/refresh-market-prices.ts via the ENTSO-E provider
/// (lib/market-price/providers/entsoe.ts) - never written to directly from
/// the Dashboard, Settings page, or Decision Engine. Read only through the
/// Market Price Provider (lib/market-price/provider.ts).
///
/// Deliberately NOT organization-scoped, unlike every other model in this
/// schema: a market price for a given bidding zone is a shared public
/// commodity value, not per-tenant data. This is a narrow, deliberate
/// exception to the multi-tenancy rule in ADR-002
/// (docs/ARCHITECT_DECISIONS.md), not an oversight.
model MarketPrice {
  id String @id @default(cuid())

  timestamp DateTime

  price Decimal @db.Decimal(10, 4)

  currency String @default("EUR")

  biddingZone String

  source String @default("ENTSOE")

  createdAt DateTime @default(now())

  @@unique([biddingZone, timestamp, source])
  @@index([biddingZone, timestamp])
}

/// Records the outcome of each market-price import run (see
/// lib/market-price/refresh-market-prices.ts). A single MarketPrice row
/// per interval can't represent "this interval is missing" (we never
/// fabricate a row for it), so this model exists to carry that status -
/// expectedIntervals/importedIntervals/isPartial/missingTimestamps - from
/// the importer through to the Dashboard via the Market Price Provider's
/// getLatestImportStatus(). Not organization-scoped, for the same reason
/// MarketPrice isn't - see that model's comment.
model MarketPriceImport {
  id String @id @default(cuid())

  biddingZone String

  periodStart DateTime
  periodEnd   DateTime

  resolutionMinutes Int

  expectedIntervals Int
  importedIntervals Int

  isPartial Boolean @default(false)

  /// ISO timestamps of intervals that were missing from the ENTSO-E
  /// response and were NOT fabricated or interpolated.
  missingTimestamps String[]

  source String @default("ENTSOE")

  importedAt DateTime @default(now())

  @@index([biddingZone, importedAt])
}

model PlantTelemetrySnapshot {
  id String @id @default(cuid())

  plantId String

  totalIncome     Decimal? @db.Decimal(18, 4)
  totalPower      Decimal? @db.Decimal(18, 4)
  dayOnGridEnergy Decimal? @db.Decimal(18, 4)
  dayPower        Decimal? @db.Decimal(18, 4)
  dayUseEnergy    Decimal? @db.Decimal(18, 4)
  dayIncome       Decimal? @db.Decimal(18, 4)
  realHealthState Int?
  monthPower      Decimal? @db.Decimal(18, 4)

  collectedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  plant Plant @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@index([plantId, collectedAt])
}

/// Resolution of a `DeviceTelemetry` sample. Only "5m" is populated as of the
/// telemetry bootstrap milestone (Huawei getDevFiveMinutes); "1h"/"1d" exist
/// so future aggregation/rollup jobs can write into the same table instead
/// of requiring a schema change.
enum TelemetryResolution {
  FIVE_MIN @map("5m")
  HOURLY   @map("1h")
  DAILY    @map("1d")
}

/// Voltessa's own telemetry store: a single, device-level, multi-resolution
/// table that every future consumer (Dashboard, Market, AI, Automation,
/// Revenue) reads from instead of importing from Huawei directly.
///
/// One row = one device's reading at one timestamp, at one resolution.
/// Deliberately not split per device type (inverter/meter) or per
/// resolution (5m/1h/1d) — see docs/AI_TASK_TEMPLATE.md task for this
/// milestone for the reasoning. Only the handful of KPIs actually queried
/// across every future layer (produced/exported/imported energy) are typed
/// columns; everything else Huawei returns is preserved unmodified in
/// `rawPayload` so no KPI is ever silently unavailable to future analytics.
///
/// Never store derived/business values here (revenue, profit, savings,
/// self-consumption, export decisions) — those belong to higher layers and
/// must always be computable from this table's raw data, never baked in.
model DeviceTelemetry {
  id String @id @default(cuid())

  organizationId String
  plantId        String
  deviceId       String

  /// Huawei's own numeric device identifier — denormalized from
  /// `Device.huaweiDeviceId` so this table is self-describing even if a
  /// device is later re-synced/re-mapped.
  huaweiDeviceId BigInt
  /// Huawei's device type (1 = inverter, 47 = meter, ...) — denormalized
  /// for the same reason.
  devTypeId Int

  timestamp  DateTime
  resolution TelemetryResolution

  ingestedAt DateTime @default(now())
  /// Always "HuaweiFusionSolar" today; stored explicitly (not assumed) so a
  /// future second vendor never has to backfill this column.
  source String @default("HuaweiFusionSolar")

  /// Instantaneous inverter production, kW (Huawei dataItemMap.active_power
  /// on the inverter device type). Null for meter rows.
  activePower Decimal? @db.Decimal(12, 3)
  /// Inverter operating state (Huawei dataItemMap.inverter_state). Null for
  /// meter rows.
  inverterState Int?
  /// Inverter temperature, °C (Huawei dataItemMap.temperature). Null for
  /// meter rows.
  temperature Decimal? @db.Decimal(6, 2)

  /// Instantaneous grid exchange power, kW (Huawei dataItemMap.active_power
  /// on the meter device type — same Huawei field name as `activePower`
  /// above, but a different physical quantity, hence a separate column).
  /// Null for inverter rows.
  meterActivePower Decimal? @db.Decimal(12, 3)
  /// Meter status (Huawei dataItemMap.meter_status). Null for inverter rows.
  meterStatus Int?
  /// Cumulative EXPORT energy counter, kWh (Huawei dataItemMap.active_cap
  /// on the meter device type). Null for inverter rows — inverters report
  /// day/lifetime cumulative production under different, non-equivalent
  /// fields (day_cap/total_cap), preserved only in `rawPayload`, not
  /// conflated with this column.
  ///
  /// CORRECTED (Historical Backfill + Timeline Alignment / Mathematical
  /// Correctness milestone): this field's real meaning is the OPPOSITE of
  /// what its original doc comment claimed ("forward/active" was assumed
  /// to mean grid import). Proven empirically against real stored data,
  /// not Huawei's naming convention: across every real meter sample for
  /// this plant, this counter increases almost exclusively while
  /// `meterActivePower` is positive, and a 25-minute daytime window where
  /// power rose from 39 kW to 60 kW moved this counter by +19.38 kWh,
  /// matching a left-Riemann integration of that same window (19.57 kWh)
  /// to within 1% — i.e. this is the real cumulative EXPORT counter. See
  /// `lib/telemetry/energy-metrics.ts`'s module doc comment and
  /// `docs/research/telemetry-consumer-migration.md` §13 for the full
  /// investigation.
  activeEnergy Decimal? @db.Decimal(14, 3)
  /// Cumulative IMPORT energy counter, kWh (Huawei
  /// dataItemMap.reverse_active_cap on the meter device type). Null for
  /// inverter rows.
  ///
  /// CORRECTED (same investigation as `activeEnergy` above): despite the
  /// "reverse/export" name Huawei's field suggests, this counter increases
  /// almost exclusively while `meterActivePower` is NEGATIVE (confirmed
  /// against real overnight standby-import windows) — i.e. this is the
  /// real cumulative IMPORT counter, not export.
  reverseActiveEnergy Decimal? @db.Decimal(14, 3)

  /// The complete, unmodified Huawei response item for this sample
  /// (devId/sn/collectTime/dataItemMap) — every KPI Huawei returns, not
  /// just the typed columns above. Future analytics reads this instead of
  /// re-importing from Huawei.
  rawPayload Json

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plant        Plant        @relation(fields: [plantId], references: [id], onDelete: Cascade)
  device       Device       @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, timestamp, resolution])
  @@index([organizationId, plantId, timestamp])
  @@index([plantId, timestamp])
}
