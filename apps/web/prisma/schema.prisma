generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  OWNER
  OPERATOR
  VIEWER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  role UserRole @default(VIEWER)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  accounts Account[]
  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String

  refresh_token String? @db.Text
  access_token  String? @db.Text
  expires_at    Int?
  token_type    String?
  scope         String?
  id_token      String? @db.Text
  session_state String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Organization {
  id String @id @default(cuid())

  name String

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  onboardingCompletedAt DateTime?

  users                  User[]
  plants                 Plant[]
  fusionSolarConnections FusionSolarConnection[]

  automationSettings AutomationSettings?
}

model Plant {
  id String @id @default(cuid())

  name String

  vendor String @default("Huawei")

  timezone String @default("Europe/Sofia")

  stationCode String?
  plantCode   String?

  capacityKw Decimal? @db.Decimal(10, 2)

  latitude  Decimal? @db.Decimal(9, 6)
  longitude Decimal? @db.Decimal(9, 6)

  country String?
  city    String?
  address String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String

  organization Organization @relation(fields: [organizationId], references: [id])

  devices Device[]

  telemetrySnapshots PlantTelemetrySnapshot[]

  @@unique([organizationId, stationCode])
}

model FusionSolarConnection {
  id String @id @default(cuid())

  organizationId String

  provider String @default("HuaweiFusionSolar")

  accessToken  String  @db.Text
  refreshToken String? @db.Text

  tokenType String?
  scope     String?

  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider])
}

model Device {
  id String @id @default(cuid())

  plantId String

  vendor String @default("Huawei")

  devDn     String
  devName   String
  devTypeId Int

  /// Huawei numeric device identifier.
  /// Used only for Huawei API calls (for example getDevRealKpi).
  /// Refreshed on every device synchronization.
  /// Not a Voltessa business identifier.
  huaweiDeviceId BigInt?

  esnCode String?
  invType String?
  model   String?

  optimizerNumber Int?
  softwareVersion String?

  latitude  Decimal? @db.Decimal(9, 6)
  longitude Decimal? @db.Decimal(9, 6)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plant Plant @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@unique([plantId, devDn])
  @@index([plantId])
  @@index([esnCode])
}

/// Per-organization automation configuration. Foundation for the Voltessa
/// Automation MVP - the Decision Engine (lib/automation/export-decision.ts)
/// reads these values as plain business inputs; it never queries this model
/// itself. `energyTrader` is a free-text placeholder today so it can later
/// evolve into a real trader integration (e.g. becoming a foreign key into
/// a future TraderIntegration table) without renaming this field. Transfer
/// costs, imbalance costs, and margins are deliberately not modeled here -
/// later milestone.
model AutomationSettings {
  id String @id @default(cuid())

  organizationId String @unique

  automationEnabled Boolean @default(false)

  minimumExportPrice Decimal @default(15.00) @db.Decimal(10, 2)

  /// Currency the organization expects minimumExportPrice to be denominated
  /// in. Does not trigger any currency conversion today - MarketPrice rows
  /// read through the Market Price Provider are compared to
  /// minimumExportPrice assuming they already match (true for the current
  /// single-market/EUR MVP scope). Converting across currencies is explicit
  /// future work, not done here.
  currency String @default("EUR")

  energyTrader String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

/// Persisted, normalized market prices (currently: ENTSO-E day-ahead
/// electricity prices). Populated only by
/// lib/market-price/refresh-market-prices.ts via the ENTSO-E provider
/// (lib/market-price/providers/entsoe.ts) - never written to directly from
/// the Dashboard, Settings page, or Decision Engine. Read only through the
/// Market Price Provider (lib/market-price/provider.ts).
///
/// Deliberately NOT organization-scoped, unlike every other model in this
/// schema: a market price for a given bidding zone is a shared public
/// commodity value, not per-tenant data. This is a narrow, deliberate
/// exception to the multi-tenancy rule in ADR-002
/// (docs/ARCHITECT_DECISIONS.md), not an oversight.
model MarketPrice {
  id String @id @default(cuid())

  timestamp DateTime

  price Decimal @db.Decimal(10, 4)

  currency String @default("EUR")

  biddingZone String

  source String @default("ENTSOE")

  createdAt DateTime @default(now())

  @@unique([biddingZone, timestamp, source])
  @@index([biddingZone, timestamp])
}

/// Records the outcome of each market-price import run (see
/// lib/market-price/refresh-market-prices.ts). A single MarketPrice row
/// per interval can't represent "this interval is missing" (we never
/// fabricate a row for it), so this model exists to carry that status -
/// expectedIntervals/importedIntervals/isPartial/missingTimestamps - from
/// the importer through to the Dashboard via the Market Price Provider's
/// getLatestImportStatus(). Not organization-scoped, for the same reason
/// MarketPrice isn't - see that model's comment.
model MarketPriceImport {
  id String @id @default(cuid())

  biddingZone String

  periodStart DateTime
  periodEnd   DateTime

  resolutionMinutes Int

  expectedIntervals Int
  importedIntervals Int

  isPartial Boolean @default(false)

  /// ISO timestamps of intervals that were missing from the ENTSO-E
  /// response and were NOT fabricated or interpolated.
  missingTimestamps String[]

  source String @default("ENTSOE")

  importedAt DateTime @default(now())

  @@index([biddingZone, importedAt])
}

model PlantTelemetrySnapshot {
  id String @id @default(cuid())

  plantId String

  totalIncome     Decimal? @db.Decimal(18, 4)
  totalPower      Decimal? @db.Decimal(18, 4)
  dayOnGridEnergy Decimal? @db.Decimal(18, 4)
  dayPower        Decimal? @db.Decimal(18, 4)
  dayUseEnergy    Decimal? @db.Decimal(18, 4)
  dayIncome       Decimal? @db.Decimal(18, 4)
  realHealthState Int?
  monthPower      Decimal? @db.Decimal(18, 4)

  collectedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  plant Plant @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@index([plantId, collectedAt])
}
