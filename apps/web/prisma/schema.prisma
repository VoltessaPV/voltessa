generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  OWNER
  OPERATOR
  VIEWER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  role UserRole @default(VIEWER)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  accounts Account[]
  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String

  refresh_token String? @db.Text
  access_token  String? @db.Text
  expires_at    Int?
  token_type    String?
  scope         String?
  id_token      String? @db.Text
  session_state String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Organization {
  id String @id @default(cuid())

  name String

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  onboardingCompletedAt DateTime?

  users                  User[]
  plants                 Plant[]
  fusionSolarConnections FusionSolarConnection[]
}

model Plant {
  id String @id @default(cuid())

  name String

  vendor String @default("Huawei")

  timezone String @default("Europe/Sofia")

  stationCode String?
  plantCode   String?

  capacityKw Decimal? @db.Decimal(10, 2)

  latitude  Decimal? @db.Decimal(9, 6)
  longitude Decimal? @db.Decimal(9, 6)

  country String?
  city    String?
  address String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String

  organization Organization @relation(fields: [organizationId], references: [id])

  devices Device[]

  telemetrySnapshots PlantTelemetrySnapshot[]

  @@unique([organizationId, stationCode])
}

model FusionSolarConnection {
  id String @id @default(cuid())

  organizationId String

  provider String @default("HuaweiFusionSolar")

  accessToken  String  @db.Text
  refreshToken String? @db.Text

  tokenType String?
  scope     String?

  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider])
}

model Device {
  id String @id @default(cuid())

  plantId String

  vendor String @default("Huawei")

  devDn     String
  devName   String
  devTypeId Int

  esnCode String?
  invType String?
  model   String?

  optimizerNumber Int?
  softwareVersion String?

  latitude  Decimal? @db.Decimal(9, 6)
  longitude Decimal? @db.Decimal(9, 6)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plant Plant @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@unique([plantId, devDn])
  @@index([plantId])
  @@index([esnCode])
}

model PlantTelemetrySnapshot {
  id String @id @default(cuid())

  plantId String

  totalIncome     Decimal? @db.Decimal(18, 4)
  totalPower      Decimal? @db.Decimal(18, 4)
  dayOnGridEnergy Decimal? @db.Decimal(18, 4)
  dayPower        Decimal? @db.Decimal(18, 4)
  dayUseEnergy    Decimal? @db.Decimal(18, 4)
  dayIncome       Decimal? @db.Decimal(18, 4)
  realHealthState Int?
  monthPower      Decimal? @db.Decimal(18, 4)

  collectedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  plant Plant @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@index([plantId, collectedAt])
}
